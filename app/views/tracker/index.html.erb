<%= turbo_stream_from "user_#{current_user.id}", :tax_report %>
<%= turbo_stream_from "user_#{current_user.id}", :sync %>
<% if @pending_report %>
  <div data-controller="auto-download" data-auto-download-url-value="<%= download_tax_report_tracker_path(country: @pending_report[:country], year: @pending_report[:year]) %>"></div>
<% end %>
<% if @portfolio_total_usd && @portfolio_total_usd.positive? %>
  <section class="dash-intro">
    <h1 class="header header--1">
      <%= number_to_currency(@portfolio_total_usd, precision: 2) %>
    </h1>
  </section>
<% end %>

<div class="two-row-filters">
  <%= render 'exchange_filters' %>
</div>

<%= render 'portfolio_chart' %>

<div class="two-row-filters">
  <div class="two-row-filters__row">
    <div class="filters">
      <%= form_tag tracker_path, method: :get, class: 'tracker-date-range', data: { controller: 'form--submit' } do %>
        <% if params[:exchange_id].present? %>
          <%= hidden_field_tag :exchange_id, params[:exchange_id] %>
        <% end %>
        <input type="date" name="from" value="<%= @date_from %>" class="sinput" data-action="change->form--submit#submit">
        <input type="date" name="to" value="<%= @date_to %>" class="sinput" data-action="change->form--submit#submit">
      <% end %>
    </div>
    <div style="display: flex; gap: 0.5rem">
      <% if @exchanges.any? %>
        <%= link_to export_modal_tracker_path, class: 'sbutton sbutton--sky', data: { turbo_frame: 'modal' } do %>
          <%= t('tracker.get_report') %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<% if @account_transactions.any? %>
  <div class="widget widget--table widget--table--tracker">
    <table class="table">
      <thead>
        <tr>
          <th class="tracker-exchange-icon"></th>
          <th class="text-left"><%= t('tracker.columns.date') %></th>
          <th><%= t('tracker.columns.type') %></th>
          <th><%= t('tracker.columns.base') %></th>
          <th><%= t('tracker.columns.amount') %></th>
          <th><%= t('tracker.columns.quote') %></th>
          <th><%= t('tracker.columns.quote_amount') %></th>
          <th><%= t('tracker.columns.fee') %></th>
          <th><%= t('tracker.columns.bot') %></th>
        </tr>
      </thead>
      <tbody>
        <% @account_transactions.each do |at| %>
          <tr class="tracker-row tracker-row--<%= at.entry_type %>">
            <td class="tracker-exchange-icon"><%= render "svg/exchange-#{at.exchange.name_id}", title: at.exchange.name %></td>
            <td  class="text-left"><%= at.transacted_at.in_time_zone(current_user.time_zone).strftime('%Y/%m/%d %H:%M:%S') %></td>
            <td><span class="tracker-type tracker-type--<%= at.entry_type %>"><%= t("tracker.types.#{at.entry_type}") %></span></td>
            <td><%= at.base_currency %></td>
            <td><%= at.base_amount %></td>
            <td><%= at.quote_currency || '-' %></td>
            <td><%= at.quote_amount.present? ? at.quote_amount : '-' %></td>
            <td><%= at.fee_amount.present? ? "#{at.fee_amount} #{at.fee_currency}" : '-' %></td>
            <td>
              <% if at.bot_transaction.present? %>
                <%= link_to at.bot_transaction.bot.label || t('tracker.bot'), bot_path(at.bot_transaction.bot) %>
              <% else %>
                -
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% elsif @exchanges.any? %>
  <div class="tracker-empty">
    <p><%= t('tracker.no_results') %></p>
  </div>
<% end %>
