<%
  slices = (@portfolio_slices || []).map do |s|
    asset = s[:asset]
    {
      label: asset.symbol,
      symbol: asset.symbol,
      name: asset.name,
      value: s[:usd_value].to_f,
      color: ensure_contrast(asset.color.presence || '#8A9BA8'),
      assetId: asset.id,
      logo: asset.image_url
    }
  end
  slices_total = slices.sum { |s| s[:value] }
%>
<%= turbo_frame_tag 'tracker-portfolio-chart', class: 'tracker-portfolio' do %>
  <% if @portfolio_never_synced %>
    <div class="tracker-portfolio__empty">
      <%= t('tracker.portfolio.never_synced') %>
    </div>
  <% elsif slices.empty? && (@portfolio_unpriced_assets || []).empty? %>
    <% if @portfolio_has_keys %>
      <div class="tracker-portfolio__empty">
        <%= t('tracker.portfolio.no_balances') %>
      </div>
    <% end %>
  <% else %>
    <% if slices.any? %>
      <div data-controller="donut-chart"
           data-donut-chart-data-value="<%= slices.to_json %>"
           data-donut-chart-storage-key-value="tracker-portfolio-view"
           data-donut-chart-other-label-value="<%= t('bot.dca_index.other') %>"
           class="tracker-portfolio__chart">
        <div class="tracker-portfolio__pie" data-donut-chart-target="pie" data-action="click->donut-chart#toggle">
          <svg data-donut-chart-target="svg"
               style="width: 100%; display: block; margin: 0 auto;"></svg>
        </div>
        <div class="tracker-portfolio__list" data-donut-chart-target="list" data-action="click->donut-chart#toggle">
          <% slices.each do |slice| %>
            <% pct = slices_total.positive? ? (slice[:value] / slices_total * 100) : 0 %>
            <div class="tracker-portfolio__asset">
              <div class="tracker-portfolio__asset-row">
                <%= tag.div slice[:symbol], class: "ticker", style: "background-color: #{slice[:color]}", data: ticker_data_for(id: slice[:assetId], symbol: slice[:symbol]) %>
                <div class="slider">
                  <div class="slider__style">
                    <div class="slider__style__track" style="border-left-color: <%= slice[:color] %>; grid-template-columns: <%= pct.round(2) %>% auto;">
                      <div class="slider__style__progress" style="background-color: <%= slice[:color] %>;"></div>
                    </div>
                  </div>
                </div>
                <div class="allocation"><%= pct.round(1) %>%</div>
                <div class="tracker-portfolio__asset-value"><%= number_to_currency(slice[:value], precision: 2) %></div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if (@portfolio_unpriced_assets || []).any? %>
      <div class="tracker-portfolio__unpriced">
        <%= t('tracker.portfolio.unpriced',
              assets: @portfolio_unpriced_assets.map(&:symbol).join(', ')) %>
      </div>
    <% end %>
  <% end %>
<% end %>
