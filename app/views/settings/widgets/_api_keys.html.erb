<div class="widget widget--settings">
  <h4 class="modal__title"><%= t('settings.index.api_keys_section') %></h4>
  <%= turbo_frame_tag "api_keys" do %>
    <h5><%= t('settings.index.trading_keys_section') %></h5>
    <div class="tags">
      <% if trading_api_keys.any? %>
        <%= render partial: 'api_key', collection: trading_api_keys, as: :api_key %>
      <% end %>
    </div>

    <% if withdrawal_api_keys.any? %>
      <h5><%= t('settings.index.withdrawal_keys_section') %></h5>
      <div class="tags">
        <%= render partial: 'api_key', collection: withdrawal_api_keys, as: :api_key %>
      </div>
    <% end %>
  <% end %>
</div>
