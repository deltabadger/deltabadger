<%# Step-3 credentials form. Also rendered from the pending_activation state so a mistyped
    consumer key / token can be corrected by resubmitting — without Start over, which would
    destroy the generated RSA keys and invalidate the IBKR-side registration. %>
<%= form_with url: settings_activate_ibkr_connection_path, method: :post, scope: :api_key, class: 'form' do |f| %>
  <div class="form__row form__row--input">
    <%= f.text_field :key, autocomplete: 'off', required: true, class: 'form__input form__input--large' %>
    <%= f.label :key, t('settings.ibkr.consumer_key'), class: 'form__label' %>
  </div>
  <p class="form__info"><%= t('settings.ibkr.consumer_key_hint') %></p>
  <div class="form__row form__row--input">
    <%= f.text_field :access_token, autocomplete: 'off', required: true, class: 'form__input form__input--large' %>
    <%= f.label :access_token, t('settings.ibkr.access_token'), class: 'form__label' %>
  </div>
  <div class="form__row form__row--input">
    <%= f.text_field :secret, autocomplete: 'off', required: true, class: 'form__input form__input--large' %>
    <%= f.label :secret, t('settings.ibkr.access_token_secret'), class: 'form__label' %>
  </div>
  <%= f.submit t('button.connect'), class: 'button button--success button--large' %>
<% end %>
