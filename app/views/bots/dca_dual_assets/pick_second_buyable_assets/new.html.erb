<%= render 'layouts/modal/full_page' do %>
  <div class="bot-creation-layout">
    <%= render partial: 'bots/dca_dual_assets/new_step_progress_bar', locals: { current_step: :currencies2 } %>

    <%= render "bots/wizard/sentence", bot: @bot, current_step: :currencies2 %>

    <%= turbo_frame_tag "asset-picker", data: { action: "keydown@window->arrow-keys-navigation#navigate", controller: "arrow-keys-navigation" }, class: "modal--search__assets selectable-options vt-step-body" do %>
      <%= form_with model: @bot, url: bots_dca_dual_assets_pick_second_buyable_asset_path, method: :post do |f| %>
        <% @assets.each do |id, symbol, name, color, category, exchanges| %>
          <%= render partial: "bots/asset_search_result", locals: { bot: @bot, asset_field: :base1_asset_id, id: id, symbol: symbol, name: name, color: color, category: category, exchanges: exchanges } %>
        <% end %>
        <% if @next_page_url %>
          <%= turbo_frame_tag @next_page_frame_id, src: @next_page_url, loading: :lazy %>
        <% end %>
      <% end %>
    <% end %>

  </div>
<% end %>
