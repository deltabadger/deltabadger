<% quote_color = ensure_contrast(bot.quote_asset&.color || "#8A9BA8") %>
<% base0_color = ensure_contrast(bot.base0_asset&.color || "#8A9BA8") %>
<% base1_color = ensure_contrast(bot.base1_asset&.color || "#8A9BA8") %>
<% base0_color_transparent = transparent_color(base0_color, bot.allocation0) %>
<% base1_color_transparent = transparent_color(base1_color, 1 - bot.allocation0) %>
<% base0 = bot.base0_asset&.symbol %>
<% base1 = bot.base1_asset&.symbol %>
<% quote = bot.quote_asset&.symbol %>
<%# Donut slices mirror the slider's target split; zero-value slices are dropped so a
    100/0 allocation renders a single full slice instead of a ghost 0% leader. %>
<% dual_slices = [
     ({ label: base0, symbol: base0, value: bot.allocation0.to_f, color: base0_color, assetId: bot.base0_asset&.id, logo: bot.base0_asset&.image_url } if bot.allocation0.to_f.positive?),
     ({ label: base1, symbol: base1, value: (1 - bot.allocation0).to_f, color: base1_color, assetId: bot.base1_asset&.id, logo: bot.base1_asset&.image_url } if (1 - bot.allocation0).to_f.positive?)
   ].compact %>

<%= form_with model: bot,
              url: path,
              method: method,
              class: "widget main-rule main-rule--dual-asset",
              data: {
                turbo_stream: true,
                controller: "form--submit form--submit-after-delay form--move-cursor-to-end bot--barbell-allocation form--html5-validations",
                bot__barbell_allocation_color0_value: base0_color,
                bot__barbell_allocation_color1_value: base1_color
              } do |f| %>
  <div class="conversational flex-justify-center">
    <%= t('bot.conversational.invest') %>
    <div class="ticker-input ticker-input--autoscale">
      <% value = bot.quote_amount.present? ? bot.quote_amount.to_d.to_s('F').sub(/([0-9]\d*)\.0$/, '\1') : 100 %>
      <%= f.number_field :quote_amount, value: value, class: 'numeric-input', step: :any, size: 2, data: { controller: "autowidth-input", action: "input->form--submit-after-delay#submit input->autowidth-input#resize", form__move_cursor_to_end_target: "input" }, autofocus: bot.new_record? && bot.quote_amount.blank?, disabled: bot.working? %>

      <% if bot.new_record? %>
        <%= link_to quote, new_bots_dca_dual_assets_pick_spendable_asset_path, data: { turbo_frame: "modal_content", **ticker_data(bot.quote_asset) }, class: "ticker" %>
      <% else %>
        <%= tag.div quote, class: "ticker", data: ticker_data(bot.quote_asset) %>
      <% end %>
    </div>
    /
    <div class="sinput sinput--select <%= 'sinput--disabled' if bot.working? %>">
      <%= t("bot.#{bot.interval}") %>
      <%= f.select :interval, bot_intervals_select_options, { selected: bot.interval }, data: { action: "change->form--submit#submit" }, disabled: bot.working? %>
    </div>
  </div>
  <%# Donut view (target allocation) only when the bot is running: the slider is then
      `disabled`, so click-to-toggle can't fight dragging. Reuses the generic `donut-chart`
      controller (as the tracker portfolio pie does); no `storageKey` => default pie,
      session-only toggle. When stopped/new, only the interactive slider renders. %>
  <% donut = bot.working? %>
  <% if donut %>
    <div data-controller="donut-chart"
         data-donut-chart-data-value="<%= dual_slices.to_json %>"
         data-donut-chart-other-label-value="<%= t('bot.dca_index.other') %>">
      <div class="barbell-pie" data-donut-chart-target="pie" data-action="click->donut-chart#toggle">
        <svg data-donut-chart-target="svg" style="width: 100%; display: block; margin: 0 auto;"></svg>
      </div>
  <% end %>
  <%# The whole `.barbell` is the `list` target, so toggling hides the plates + bar together. %>
  <%= tag.div class: "barbell", data: (donut ? { donut_chart_target: "list", action: "click->donut-chart#toggle" } : {}) do %>
    <div class="barbell__plate">
      <% if bot.new_record? %>
        <%= link_to base0, new_bots_dca_single_assets_pick_buyable_asset_path, data: { turbo_frame: "modal_content", bot__barbell_allocation_target: "allocation0BackgroundColor", **ticker_data(bot.base0_asset) }, class: ticker_class(bot.base0_asset), style: "background: #{base0_color_transparent}" %>
      <% else %>
        <%= tag.div base0, class: ticker_class(bot.base0_asset), style: "background: #{base0_color_transparent}", data: { bot__barbell_allocation_target: "allocation0BackgroundColor", **ticker_data(bot.base0_asset) } %>
      <% end %>
      <b style="color: <%= base0_color_transparent %>" data-bot--barbell-allocation-target="allocation0Color"><span data-bot--barbell-allocation-target="allocation0Text"><%= (bot.allocation0 * 100).to_i %></span>%</b>
    </div>

    <div class="barbell__bar">
      <div class="slider slider--dual">
        <%= f.range_field :allocation0, in: 0.0..1.0, step: 0.01, value: bot.allocation0, class: "slider__input numeric-input", data: { bot__barbell_allocation_target: "allocation0", action: "input->bot--barbell-allocation#updateAllocation0 change->form--submit#submit" }, disabled: bot.marketcap_allocated? || bot.working? %>
          <div class="slider__style">
            <%= tag.div class: "slider__style__track", style: "border-left-color: #{base0_color_transparent}; border-right-color: #{base1_color_transparent}; grid-template-columns: #{bot.allocation0 * 100}% auto;", data: { bot__barbell_allocation_target: "allocation0SliderTrack" } do %>
              <%= tag.div class: "slider__style__progress", style: "background: #{base0_color_transparent}", data: { bot__barbell_allocation_target: "allocation0SliderProgress" } do %>
              <div class="slider__style__thumb"></div>
            <% end %>
            <%= tag.div class: "slider__style__othervalue", style: "background: #{base1_color_transparent};", data: { bot__barbell_allocation_target: "allocation1SliderOthervalue" } %>
          <% end %>

        </div>
      </div>
    </div>

    <div class="barbell__plate">
      <% if bot.new_record? %>
        <%= link_to base1, new_bots_dca_dual_assets_pick_second_buyable_asset_path, data: { turbo_frame: "modal_content", bot__barbell_allocation_target: "allocation1BackgroundColor", **ticker_data(bot.base1_asset) }, class: ticker_class(bot.base1_asset), style: "background: #{base1_color_transparent}" %>
      <% else %>
        <%= tag.div base1, class: ticker_class(bot.base1_asset), style: "background: #{base1_color_transparent}", data: { bot__barbell_allocation_target: "allocation1BackgroundColor", **ticker_data(bot.base1_asset) } %>
      <% end %>
      <b style="color: <%= base1_color_transparent %>" data-bot--barbell-allocation-target="allocation1Color"><span data-bot--barbell-allocation-target="allocation1Text"><%= ((1 - bot.allocation0).round(2) * 100).to_i %></span>%</b>
    </div>
  <% end %>
  <% if donut %>
    </div>
  <% end %>
<% end %>
