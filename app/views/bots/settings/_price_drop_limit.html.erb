<%# Active side: render the buy-side keys while buying, the sell-side mirror while selling (M5). %>
<% pfx = trigger_prefix(bot, 'price_drop_limit') %>
<% limited_field = :"#{pfx}ed" %>
<% active_in_ticker_id = bot.public_send("#{pfx}_in_ticker_id") %>
<% active_time_window_condition = bot.public_send("#{pfx}_time_window_condition") %>

<%= form_with model: bot,
              url: path,
              method: method,
              class: "widget rule #{bot.active_price_drop_limited? ? "rule--active" : "rule--inactive"}",
              data: {
                controller: "class-toggle form--submit form--submit-after-delay form--move-cursor-to-end form--html5-validations",
                class_toggle_target: "togglable",
                class_toggle_toggle_classes_value: ["rule--active", "rule--inactive"],
                turbo_stream: true
              } do |f| %>
  <div class="toggle-group">
    <div class="toggle">
      <%= f.check_box limited_field, data: { action: "change->form--submit#submit change->class-toggle#toggle" }, disabled: bot.working? %>
      <div class="toggle__style"></div>
    </div>
    <div class="toggle-group__info">
      <div class="toggle-group__info__label">
        <%= f.label limited_field, class: "conversational conversational--small conversational--disabled" do %>
          <%# Merged mode select (issues #1/#2): leads the sentence ("Start buying/selling …" / flip).
              Non-reversible bots have only the single "Start buying" verb, so they render plain text
              rather than a pointless one-option select (price-drop has no while/after to add a token). %>
          <% current_mode = trigger_mode_for(bot, 'price_drop_limit') %>
          <% if bot.reversible? %>
            <% mode_html = content_tag(:div, class: "sinput sinput--select #{'sinput--disabled' if bot.working?}") do %>
              <%= t("bot.settings.trigger_mode.#{current_mode}_#{bot.selling? ? 'selling' : 'buying'}") %>
              <%= f.select :"#{pfx}_mode", trigger_mode_select_options(bot, 'price_drop_limit'), { selected: current_mode }, data: { action: "change->form--submit#submit" }, disabled: bot.working? %>
            <% end %>
          <% else %>
            <% mode_html = t("bot.settings.trigger_mode.start_buying") %>
          <% end %>
          <% base_select_options = base_select_options(bot) %>
          <% if base_select_options.size > 1 %>
            <% base_html = content_tag(:div, class: "sinput sinput--select #{'sinput--disabled' if bot.working?}") do %>
              <%= base_select_options.find { |_, id| id == active_in_ticker_id }&.first %>
              <%= f.select :"#{pfx}_in_ticker_id", base_select_options, { selected: active_in_ticker_id }, data: { action: "change->form--submit#submit" }, disabled: bot.working? %>
            <% end %>
          <% else %>
            <% base_html = base_select_options.first&.first || "" %>
          <% end %>
          <% value_html = content_tag(:div) do %>
            <% limit = bot.public_send(pfx) %>
            <% value = limit.present? ? (limit.to_d * 100).to_s('F').sub(/([0-9]\d*)\.0$/, '\1') : nil %>
            <%= f.number_field pfx.to_sym, value: value, class: 'sinput numeric-input', step: :any, size: 2, data: { controller: "autowidth-input", action: "input->form--submit-after-delay#submit input->autowidth-input#resize", form__move_cursor_to_end_target: "input" }, style: "margin-left: 0.125rem; width: 50px;", disabled: bot.working? %>
          <% end %>
          <% window_namespace = bot.selling? ? 'sell_time_window_condition' : 'time_window_condition' %>
          <% time_window_condition_html = content_tag(:div, class: "sinput sinput--select #{'sinput--disabled' if bot.working?}") do %>
            <%= t("bot.settings.extra_price_drop_limit.#{window_namespace}.#{active_time_window_condition}") %>
            <%= f.select :"#{pfx}_time_window_condition", price_drop_limit_time_window_condition_select_options(bot), { selected: active_time_window_condition }, data: { action: "change->form--submit#submit" }, disabled: bot.working? %>
          <% end %>
          <%# Buy: "… when price drops X% from its high"; sell inverts to "… rises X% from its low".
              New key names (…mode_sentence_html) so untranslated locales fall back to English. %>
          <%= t("bot.settings.extra_price_drop_limit.#{bot.selling? ? 'sell_mode_sentence_html' : 'mode_sentence_html'}",
                mode_html: mode_html.html_safe,
                base_html: base_html.html_safe,
                value_html: value_html.html_safe,
                time_window_condition_html: time_window_condition_html.html_safe,
                count: base_select_options.size).html_safe %>
          <%= render partial: "bots/settings/price_drop_limit_info", locals: { bot: bot, info: bot.price_drop_limit_info_from_cache } %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
